# Copy this to .env for local dev. In Railway: add under Variables tab.

# Mentra — from console.mentra.glass
MENTRA_API_KEY=your_mentra_api_key_here
MENTRA_PACKAGE_NAME=com.yourcompany.mentralivetest

# Gemini — from aistudio.google.com/apikey (free)
GEMINI_API_KEY=AIza...

# Postgres — Railway fills this in automatically from the Postgres plugin
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Railway sets PORT automatically
PORT=3000
